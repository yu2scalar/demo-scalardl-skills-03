# Build / IDE
**/build/
**/.gradle/
**/out/
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
*.swp

# Compiled bytecode
**/compiled/

# Note: generated/ is tracked in this demo repo so reviewers can see the
# rendered Java without running ./gradlew render. Files here include both
# scaffold-rendered V1_0_0 templates and any hand-rolled V1_0_x customisations.

# Cert / private keys (never commit secrets)
# Cert files are environment-specific; even public certs are excluded from this repo.
**/cert/*.key
**/cert/*.pem
**/cert/*.pkcs8
**/cert/*.cert
**/cert/*.crt
!**/cert/.gitkeep

# Application local overrides
**/src/main/resources/application-local.properties
